{
  "format": "resonance.arrangement/v1",
  "name": "demo_room",
  "_doc": "Visi-sonor arc Slice 1C (item 3) — a small demo ROOM SHELL + controllable lighting fixtures, authored purely as a NODE ARRANGEMENT (the room-is-an-arrangement pattern), reusing existing primitives: Environment (iterable sky), AssetImport (fixtures + shell, placeholder-safe), Light (per-fixture KHR_lights_punctual descriptor + device addr), LedStrip (per-pixel-addressable strip), TextureApply (ambientCG wall/floor materials), Group (compose to one scene_node). NO audio / freq-mapping / screen here — those are other Wave-1 slices that wire INTO this room's fixtures via each Light's addr. Each fixture is drivable by BOTH the 3D renderer (its Light descriptor) AND a real WLED (its addr via device.set_led). The shell + lamp GLBs are absent until fetched (see assets/manifest_lighting_room.json); AssetImport falls back to placeholder box/cylinder meshes so this room renders + self-tests headless with zero network fetch (C-ideal), upgrading to real GLBs when they land.",
  "nodes": [
    { "id": "sky", "type": "Environment", "params": { "sun_energy": 0.6, "ambient_energy": 0.4 } },

    { "id": "shell", "type": "AssetImport", "params": { "id": "room_shell", "manifest_path": "res://assets/manifest_lighting_room.json", "name": "room_shell", "placeholder_shape": "box", "placeholder_params": { "width": 8.0, "height": 4.0, "depth": 8.0 } } },
    { "id": "floor_mat", "type": "TextureApply", "params": { "cell": [0, 0, 0], "material": { "albedo_texture": "res://assets/vendor/ambientcg/WoodFloor043_1K-JPG_Color.jpg", "albedo": [0.55, 0.42, 0.28], "roughness": 0.8 } } },
    { "id": "wall_mat", "type": "TextureApply", "params": { "cell": [0, 1, 0], "material": { "albedo_texture": "res://assets/vendor/ambientcg/Plaster001_1K-JPG_Color.jpg", "albedo": [0.86, 0.84, 0.80], "roughness": 0.9 } } },

    { "id": "lamp_a_mesh", "type": "AssetImport", "params": { "id": "kenney_furniture__lamp_round_floor", "manifest_path": "res://assets/manifest_lighting_room.json", "name": "lamp_a", "placeholder_shape": "cylinder" } },
    { "id": "lamp_a_light", "type": "Light", "params": { "type": "point", "color": [1.0, 0.85, 0.6], "intensity": 3.0, "position": [-2.5, 2.2, -2.5], "range": 6.0, "addr": 0 } },

    { "id": "lamp_b_mesh", "type": "AssetImport", "params": { "id": "kenney_furniture__lamp_round_table", "manifest_path": "res://assets/manifest_lighting_room.json", "name": "lamp_b", "placeholder_shape": "cylinder" } },
    { "id": "lamp_b_light", "type": "Light", "params": { "type": "point", "color": [0.6, 0.8, 1.0], "intensity": 2.5, "position": [2.5, 1.0, -2.5], "range": 5.0, "addr": 1 } },

    { "id": "lamp_c_mesh", "type": "AssetImport", "params": { "id": "poly_haven__ceiling_lamp_01", "manifest_path": "res://assets/manifest_lighting_room.json", "name": "lamp_c", "placeholder_shape": "cylinder" } },
    { "id": "lamp_c_light", "type": "Light", "params": { "type": "spot", "color": [1.0, 1.0, 0.9], "intensity": 4.0, "position": [0.0, 3.6, 0.0], "rotation": [-90.0, 0.0, 0.0], "range": 8.0, "inner_cone_deg": 25.0, "outer_cone_deg": 40.0, "addr": 2 } },

    { "id": "strip", "type": "LedStrip", "params": { "count": 12, "base_addr": 100, "start": [-3.0, 2.6, 3.0], "end": [3.0, 2.6, 3.0], "color": [0.2, 0.6, 1.0], "intensity": 1.5, "range": 3.0 } },

    { "id": "room", "type": "Group", "params": { "count": 4, "name": "demo_room" } }
  ],
  "wires": [
    { "from": "shell", "out": "node", "to": "room", "in": "in_0" },
    { "from": "lamp_a_mesh", "out": "node", "to": "room", "in": "in_1" },
    { "from": "lamp_b_mesh", "out": "node", "to": "room", "in": "in_2" },
    { "from": "lamp_c_mesh", "out": "node", "to": "room", "in": "in_3" }
  ]
}
