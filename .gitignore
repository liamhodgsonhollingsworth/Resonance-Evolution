# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.venv/
venv/
env/

# Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Engine output
output/
.cache/
*.npy

# Godot asset-import descriptors — DERIVED from source assets + .godot/ on editor open, so they are
# cache noise, not substrate. They MUST be gitignored: Godot rewrites them every open, and a dirty
# *.import worktree can silently block the desktop shortcut's `git pull --ff-only` (breaking the
# "merged updates must reach the shortcut" guarantee). Untracked; regenerated on open.
*.import

# Godot headless test-capture scratch — stdout/stderr redirects captured at the repo root
# when running headless Godot suites (e.g. `godot ... > out.txt 2> err.txt`). Captured console
# output, not source; accidentally committed by de3e600 (#181). Root-anchored so real .txt files
# (godot/**/LICENSE.txt, logs/sample_chat.txt) stay tracked.
/out.txt
/err.txt
/*_out.txt
/*_err.txt

# Workflow shell runtime state (sessions, raw logs, local inbox)
state/

# Claude Code worktrees
.claude/worktrees/
